{
  "name": "claude-trace",
  "version": "0.1.0",
  "description": "Zero-configuration OpenTelemetry observability for Claude Agent SDK",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "wasm"
  ],
  "scripts": {
    "build:wasm": "wasm-pack build ../../crates/claude-trace-wasm --target nodejs --out-dir ../../typescript/wasm",
    "build:ts": "tsc -p tsconfig.build.json && tsc -p tsconfig.esm.json",
    "build": "npm run build:wasm && npm run build:ts",
    "test": "jest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-trace-node": "^1.25.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.36.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^22.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/agentglass/claude-trace"
  },
  "keywords": [
    "anthropic",
    "claude",
    "opentelemetry",
    "observability",
    "agents",
    "tracing"
  ]
}
